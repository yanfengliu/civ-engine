  const ok = stopReason !== 'sinkError' && recorder.lastError === null;
  const bundle = recorder.toBundle() as unknown as SessionBundle<TEventMap, TCommandMap, TDebug>;
  return { bundle, ticksRun, stopReason, ok, policyError };
}
