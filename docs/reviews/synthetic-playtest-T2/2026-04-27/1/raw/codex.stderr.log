          const actual = [...world.getEvents()] as Array<{ type: PropertyKey; data: unknown }>;
          if (!deepEqualOrdered(expected, actual)) {
            eventDivs.push({ tick: t + 1, expected: expected as Array<{ type: PropertyKey; data: unknown }>, actual });
