48:>(): Policy<TEventMap, TCommandMap, TComponents, TState> {
49:  return () => [];
50:}
51:
52:export type ScriptedPolicyEntry<TCommandMap> = {
53:  [K in keyof TCommandMap & string]: { tick: number; type: K; data: TCommandMap[K] };
54:}[keyof TCommandMap & string];
55:
56:export function scriptedPolicy<
57:  TEventMap extends Record<keyof TEventMap, unknown>,
58:  TCommandMap extends Record<keyof TCommandMap, unknown>,
59:  TComponents extends ComponentRegistry = Record<string, unknown>,
60:  TState extends Record<string, unknown> = Record<string, unknown>,
61:>(
62:  sequence: ScriptedPolicyEntry<TCommandMap>[],
63:): Policy<TEventMap, TCommandMap, TComponents, TState> {
64:  const byTick = new Map<number, PolicyCommand<TCommandMap>[]>();
65:  for (const entry of sequence) {
66:    const list = byTick.get(entry.tick);
67:    const cmd = { type: entry.type, data: entry.data } as PolicyCommand<TCommandMap>;
68:    if (list) list.push(cmd);
69:    else byTick.set(entry.tick, [cmd]);
70:  }
71:  return (ctx) => byTick.get(ctx.tick) ?? [];
72:}
73:
74:export interface RandomPolicyConfig<
75:  TEventMap extends Record<keyof TEventMap, unknown>,
76:  TCommandMap extends Record<keyof TCommandMap, unknown>,
77:  TComponents extends ComponentRegistry = Record<string, unknown>,
78:  TState extends Record<string, unknown> = Record<string, unknown>,
79:> {
80:  catalog: Array<(ctx: PolicyContext<TEventMap, TCommandMap, TComponents, TState>) => PolicyCommand<TCommandMap>>;
81:  frequency?: number;
82:  offset?: number;
83:  burst?: number;
84:}
85:
86:export function randomPolicy<
87:  TEventMap extends Record<keyof TEventMap, unknown>,
88:  TCommandMap extends Record<keyof TCommandMap, unknown>,
89:  TComponents extends ComponentRegistry = Record<string, unknown>,
90:  TState extends Record<string, unknown> = Record<string, unknown>,
91:>(
92:  config: RandomPolicyConfig<TEventMap, TCommandMap, TComponents, TState>,
93:): Policy<TEventMap, TCommandMap, TComponents, TState> {
94:  const { catalog, frequency = 1, offset = 0, burst = 1 } = config;
95:  if (catalog.length === 0) {
96:    throw new RangeError('randomPolicy.catalog must be non-empty');
97:  }
98:  if (!Number.isInteger(frequency) || frequency < 1) {
99:    throw new RangeError('randomPolicy.frequency must be a positive integer');
100:  }
101:  if (!Number.isInteger(burst) || burst < 1) {
102:    throw new RangeError('randomPolicy.burst must be a positive integer');
103:  }
104:  if (!Number.isInteger(offset) || offset < 0 || offset >= frequency) {
105:    throw new RangeError(
106:      `randomPolicy.offset must be a non-negative integer < frequency (got ${offset}, frequency=${frequency})`,
107:    );
108:  }
109:  return (ctx) => {
110:    if (ctx.tick % frequency !== offset) return [];
111:    const out: PolicyCommand<TCommandMap>[] = [];
112:    for (let i = 0; i < burst; i++) {
113:      const idx = Math.floor(ctx.random() * catalog.length);
114:      out.push(catalog[idx](ctx));
115:    }
116:    return out;
117:  };
118:}
