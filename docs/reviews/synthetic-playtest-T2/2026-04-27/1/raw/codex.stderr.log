    } catch (e) {
      this._handleSinkError(e);
    }
  }

  private _handleSinkError(e: unknown): void {
    const err = e instanceof SessionRecordingError ? e : new SinkWriteError(
      String((e as Error)?.message ?? e),
      { wrapped: true, original: String(e) },
