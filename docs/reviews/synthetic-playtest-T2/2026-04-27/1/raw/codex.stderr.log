120:export interface SynthPlaytestConfig<
121:  TEventMap extends Record<keyof TEventMap, unknown>,
122:  TCommandMap extends Record<keyof TCommandMap, unknown>,
123:  TComponents extends ComponentRegistry = Record<string, unknown>,
124:  TState extends Record<string, unknown> = Record<string, unknown>,
125:> {
126:  world: World<TEventMap, TCommandMap, TComponents, TState>;
127:  policies: Policy<TEventMap, TCommandMap, TComponents, TState>[];
128:  maxTicks: number;
129:  sink?: SessionSink & SessionSource;
130:  sourceLabel?: string;
131:  policySeed?: number;
132:  stopWhen?: (ctx: StopContext<TEventMap, TCommandMap, TComponents, TState>) => boolean;
133:  snapshotInterval?: number | null;
134:}
135:
136:export interface SynthPlaytestResult<
137:  TEventMap extends Record<keyof TEventMap, unknown>,
138:  TCommandMap extends Record<keyof TCommandMap, unknown>,
139:  TDebug = JsonValue,
140:> {
141:  bundle: SessionBundle<TEventMap, TCommandMap, TDebug>;
142:  ticksRun: number;
143:  stopReason: 'maxTicks' | 'stopWhen' | 'poisoned' | 'policyError' | 'sinkError';
144:  ok: boolean;
145:  policyError?: {
146:    policyIndex: number;
147:    tick: number;
148:    error: { name: string; message: string; stack: string | null };
149:  };
150:}
151:
152:export function runSynthPlaytest<
153:  TEventMap extends Record<keyof TEventMap, unknown>,
154:  TCommandMap extends Record<keyof TCommandMap, unknown>,
155:  TComponents extends ComponentRegistry = Record<string, unknown>,
156:  TState extends Record<string, unknown> = Record<string, unknown>,
157:  TDebug = JsonValue,
158:>(
159:  config: SynthPlaytestConfig<TEventMap, TCommandMap, TComponents, TState>,
160:): SynthPlaytestResult<TEventMap, TCommandMap, TDebug> {
161:  // Step 1: validation.
162:  if (!Number.isInteger(config.maxTicks) || config.maxTicks < 1) {
163:    throw new RangeError(`maxTicks must be a positive integer (got ${config.maxTicks})`);
164:  }
165:  if (config.policySeed !== undefined && !Number.isInteger(config.policySeed)) {
166:    throw new RangeError(`policySeed must be a finite integer (got ${config.policySeed})`);
167:  }
168:
169:  const { world, policies, maxTicks, sink, sourceLabel } = config;
170:  // Use 'in' to distinguish unset from explicit-null (??1000 would coerce null to 1000 — null disables periodic snapshots).
171:  const snapshotInterval: number | null =
172:    'snapshotInterval' in config && config.snapshotInterval !== undefined
173:      ? config.snapshotInterval
174:      : 1000;
175:
176:  // Step 2: sub-RNG init (BEFORE recorder.connect so initial snapshot reflects post-derivation world.rng state).
177:  // ADR 19: Math.floor(world.random() * 0x1_0000_0000) scales [0,1) to a uint32 — required because
178:  // DeterministicRandom.seedToUint32's Math.trunc(x)>>>0 collapses [0,1) to 0.
179:  const policySeed = config.policySeed ?? Math.floor(world.random() * 0x1_0000_0000);
180:  const subRng = new DeterministicRandom(policySeed);
181:  const random = (): number => subRng.random();
182:
183:  // Step 3: recorder attach. terminalSnapshot:true is hardcoded — every bundle gets the
184:  // (initial, terminal) segment so SessionReplayer.selfCheck has a non-empty segment to validate.
185:  const effectiveSink: SessionSink & SessionSource = sink ?? new MemorySink();
186:  // SessionRecorder is 3-generic (no TComponents/TState); doesn't access them. Cast is structurally safe.
187:  const recorder = new SessionRecorder<TEventMap, TCommandMap, TDebug>({
188:    world: world as unknown as World<TEventMap, TCommandMap>,
189:    sink: effectiveSink,
190:    snapshotInterval,
191:    terminalSnapshot: true,
192:    sourceLabel: sourceLabel ?? 'synthetic',
193:    sourceKind: 'synthetic',
194:    policySeed,
195:  });
196:  recorder.connect();
197:  if (recorder.lastError !== null) {
198:    // Connect-time sink failure: propagate. recorder.connect() does NOT throw on
199:    // sink.open() failure — it sets _lastError + _terminated and returns. The initial
200:    // snapshot may not have been persisted, so there's no coherent bundle to return.
201:    const err = recorder.lastError;
202:    try { recorder.disconnect(); } catch { /* best-effort */ }
203:    throw err;
204:  }
205:
206:  // Step 4: tick loop.
207:  let ticksRun = 0;
208:  let stopReason: SynthPlaytestResult<TEventMap, TCommandMap, TDebug>['stopReason'] = 'maxTicks';
209:  let policyError: SynthPlaytestResult<TEventMap, TCommandMap, TDebug>['policyError'];
210:
211:  outer: for (let i = 0; i < maxTicks; i++) {
212:    const policyCtx: PolicyContext<TEventMap, TCommandMap, TComponents, TState> = {
213:      world, tick: world.tick + 1, random,
214:    };
215:    for (let p = 0; p < policies.length; p++) {
216:      let cmds: PolicyCommand<TCommandMap>[];
217:      try {
218:        cmds = policies[p](policyCtx);
219:      } catch (err) {
220:        const e = err as Error;
221:        stopReason = 'policyError';
222:        policyError = {
223:          policyIndex: p,
224:          tick: policyCtx.tick,
225:          error: { name: e.name ?? 'Error', message: e.message ?? String(e), stack: e.stack ?? null },
226:        };
227:        break outer;
228:      }
229:      for (const cmd of cmds) {
230:        world.submitWithResult(cmd.type, cmd.data);
231:      }
232:    }
233:    try {
234:      world.step();
235:    } catch {
236:      stopReason = 'poisoned';
237:      break;
238:    }
239:    if (recorder.lastError !== null) {
240:      stopReason = 'sinkError';
241:      break;
242:    }
243:    ticksRun++;
244:    const stopCtx: StopContext<TEventMap, TCommandMap, TComponents, TState> = {
245:      world, tick: world.tick, random,
246:    };
247:    if (config.stopWhen?.(stopCtx)) {
248:      stopReason = 'stopWhen';
249:      break;
250:    }
251:  }
252:
253:  // Step 5: disconnect + return.
254:  try { recorder.disconnect(); } catch { /* best-effort */ }
255:  // Tighten ok: also flips false if disconnect-time sink failure occurred.
256:  const ok = stopReason !== 'sinkError' && recorder.lastError === null;
257:  const bundle = recorder.toBundle() as unknown as SessionBundle<TEventMap, TCommandMap, TDebug>;
258:  return { bundle, ticksRun, stopReason, ok, policyError };
259:}
