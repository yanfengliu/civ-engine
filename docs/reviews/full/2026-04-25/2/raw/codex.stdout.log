    grid.occupy(11, { x: 1, y: 0 });
    grid.occupy(12, { x: 1, y: 2 });

    expect(grid.neighborsWithSpace(4, { x: 1, y: 1 })).toEqual([
      {
        position: { x: 0, y: 1 },
        freeSlots: 4,
        bestSlot: {
          position: { x: 0, y: 1 },
          slot: 0,
          offset: { x: 0, y: 0 },
        },
      },
      {
        position: { x: 1, y: 2 },
        freeSlots: 3,
        bestSlot: {
