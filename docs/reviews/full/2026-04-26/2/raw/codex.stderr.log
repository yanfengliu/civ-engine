      expect(() => layer.setCell(0, -1, 1)).toThrow();
      expect(() => layer.setCell(4, 0, 1)).toThrow();
      expect(() => layer.setCell(0, 4, 1)).toThrow();
      expect(() => layer.getCell(4, 0)).toThrow();
