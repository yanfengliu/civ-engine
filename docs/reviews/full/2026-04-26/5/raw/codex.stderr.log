      expect(observedRef).not.toBeNull();
      // Same object across iterations: live reference, no clone.
      let again: { n: number } | null = null;
      layer.forEachReadOnly((value, cx, cy) => {
        if (cx === 0 && cy === 0) again = value;
      });
      expect(again).toBe(observedRef);
    });
  });

