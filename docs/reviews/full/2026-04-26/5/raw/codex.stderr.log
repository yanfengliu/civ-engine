        worldWidth: 2,
        worldHeight: 2,
        defaultValue: false,
      });
      layer.setCell(0, 0, true);
      expect(layer.getCell(0, 0)).toBe(true);
      expect(layer.getCell(1, 1)).toBe(false);
    });

