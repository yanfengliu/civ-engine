  findNearest(
    cx: number,
    cy: number,
    ...components: string[]
  ): EntityId | undefined {
    const w = this.spatialGrid.width;
    const h = this.spatialGrid.height;
    const maxRadius = Math.ceil(Math.hypot(Math.max(w - 1, 0), Math.max(h - 1, 0)));
    const mask = components.length > 0 ? this.queryMask(components) : 0n;
