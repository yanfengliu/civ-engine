        worldWidth: 2,
        worldHeight: 2,
        defaultValue: { n: 0 },
      });
      layer.setCell(0, 0, { n: 5 });
      let observedRef: { n: number } | null = null;
      layer.forEachReadOnly((value, cx, cy) => {
        if (cx === 0 && cy === 0) observedRef = value;
