      expect(layer.getCell(1, 1)).toBe(42);
      expect(layer.getCell(0, 0)).toBe(0);
      let count = 0;
      layer.forEach((v) => {
        if (v === 42) count++;
      });
      expect(count).toBe(1);
    });

    it('Layer<boolean> reads return correct value', () => {
