        return cell ? new Set(cell) : null;
      },
      getNeighbors: (x, y, offsets) => grid.getNeighbors(x, y, offsets),
      getInRadius: (cx, cy, radius, metric) => grid.getInRadius(cx, cy, radius, metric),
