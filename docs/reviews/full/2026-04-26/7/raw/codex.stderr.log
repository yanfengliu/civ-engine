  private rebuildComponentSignatures(): void {
    this.componentBits.clear();
    this.nextComponentBit = 0;
    this.entitySignatures = [];
    this.queryCache.clear();

    for (const key of this.componentStores.keys()) {
      this.registerComponentBit(key);
