    const wrappedSink = new Proxy(memorySink, {
      get(target, prop) {
        if (prop === 'writeSnapshot') {
          return (entry: unknown) => {
            writes++;
            if (writes > 1) throw new Error('disk-full');
            return (target as any).writeSnapshot(entry);
