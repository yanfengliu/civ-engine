    expect(bundle.markers).toHaveLength(1);
    expect(bundle.ticks).toHaveLength(1);
  });

  it('toBundle() throws if no snapshots written', () => {
    const sink = new FileSink(bundleDir);
    sink.open(mkMetadata());
