  it('policyError: policy throw stops with stopReason "policyError" + populated policyError', () => {
    const world = mkWorld();
    const throwingPolicy = (ctx: PolicyContext<Record<string, never>, Cmds>) => {
      if (ctx.tick === 3) throw new Error('policy-bug');
