+      commandValidationAcceptanceRate() as Metric<unknown, unknown>,
+      executionFailureRate() as Metric<unknown, unknown>,
+    ];
+    expect(runMetrics([a], allBuiltins())).toEqual(runMetrics([b], allBuiltins()));
+  });
