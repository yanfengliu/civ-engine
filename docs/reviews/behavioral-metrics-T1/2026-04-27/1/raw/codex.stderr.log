+
+// ---------- incompleteBundleRate ----------
+describe('incompleteBundleRate', () => {
+  it('empty corpus → 0', () => {
+    expect(runMetrics([], [incompleteBundleRate()]).incompleteBundleRate).toBe(0);
+  });
+  it('mixed → ratio', () => {
