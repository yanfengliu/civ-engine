+  ref: { dataUrl: string } | { sidecar: true };
+}
+
+export interface SessionMetadata {
+  sessionId: string;
+  engineVersion: string;
+  nodeVersion: string;
+  recordedAt: string;
+  startTick: number;
+  endTick: number;
+  persistedEndTick: number;
+  durationTicks: number;
