              result.ok = false;
              break;
            }
          }
        } catch (e) {
          result.invalidMarkers.push({
            markerId: marker.id,
            reason: `replay failed: ${(e as Error).message}`,
          });
          result.ok = false;
        }
      }
    }
    return result;
  }

