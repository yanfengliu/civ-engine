531:export function failureBundleRate(
532:  name: string = 'failureBundleRate',
533:): Metric<{ withFailure: number; total: number }, number> {
534:  return {
535:    name,
536:    create: () => ({ withFailure: 0, total: 0 }),
537:    observe: (state, bundle) => {
538:      state.total++;
