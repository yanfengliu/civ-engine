806:### Step 9: Implement `compareMetricsResults`
807:
808:- [ ] Append to `src/behavioral-metrics.ts`:
809:
810:```ts
811:export type NumericDelta = {
812:  baseline: number | null;
813:  current: number | null;
814:  delta: number | null;
815:  pctChange: number | null;
816:};
817:
818:export type OpaqueDelta = {
819:  baseline: unknown;
820:  current: unknown;
821:  equal: boolean;
822:};
823:
824:export type OnlyInComparison = {
825:  baseline?: unknown;
826:  current?: unknown;
827:  onlyIn: 'baseline' | 'current';
828:};
829:
830:export type MetricDelta =
831:  | NumericDelta
832:  | OpaqueDelta
833:  | { [key: string]: MetricDelta | OnlyInComparison };
834:
835:export type MetricsComparison = Record<string, MetricDelta | OnlyInComparison>;
836:
837:function isPlainObject(value: unknown): value is Record<string, unknown> {
838:  return typeof value === 'object' && value !== null && !Array.isArray(value)
839:    && Object.getPrototypeOf(value) === Object.prototype;
840:}
841:
842:function deepEqual(a: unknown, b: unknown): boolean {
843:  if (a === b) return true;
844:  if (typeof a !== typeof b) return false;
845:  if (a === null || b === null) return a === b;
846:  if (Array.isArray(a) && Array.isArray(b)) {
847:    if (a.length !== b.length) return false;
848:    for (let i = 0; i < a.length; i++) if (!deepEqual(a[i], b[i])) return false;
849:    return true;
850:  }
851:  if (isPlainObject(a) && isPlainObject(b)) {
852:    const aKeys = Object.keys(a);
853:    const bKeys = Object.keys(b);
854:    if (aKeys.length !== bKeys.length) return false;
855:    for (const k of aKeys) if (!deepEqual(a[k], b[k])) return false;
856:    return true;
857:  }
858:  return false;
859:}
860:
861:function compareValue(baseline: unknown, current: unknown): MetricDelta {
862:  // Numeric leaves (with null support).
863:  if ((typeof baseline === 'number' || baseline === null) &&
864:      (typeof current === 'number' || current === null)) {
865:    if (baseline === null || current === null) {
866:      return { baseline, current, delta: null, pctChange: null };
867:    }
868:    const delta = current - baseline;
869:    let pctChange: number | null;
870:    if (baseline === 0) {
871:      pctChange = current === 0 ? 0 : (current > 0 ? Infinity : -Infinity);
872:    } else {
873:      pctChange = (current - baseline) / baseline;
874:    }
875:    return { baseline, current, delta, pctChange };
876:  }
877:  // Plain-object recurse.
878:  if (isPlainObject(baseline) && isPlainObject(current)) {
879:    const out: Record<string, MetricDelta | OnlyInComparison> = {};
880:    const allKeys = new Set([...Object.keys(baseline), ...Object.keys(current)]);
881:    for (const k of allKeys) {
882:      const inB = k in baseline;
883:      const inC = k in current;
884:      if (inB && inC) {
885:        out[k] = compareValue(baseline[k], current[k]);
886:      } else if (inB) {
887:        out[k] = { baseline: baseline[k], onlyIn: 'baseline' };
888:      } else {
889:        out[k] = { current: current[k], onlyIn: 'current' };
890:      }
891:    }
892:    return out;
893:  }
894:  // Opaque (arrays, type mismatches, strings, booleans).
895:  return { baseline, current, equal: deepEqual(baseline, current) };
896:}
897:
898:export function compareMetricsResults(
899:  baseline: MetricsResult,
900:  current: MetricsResult,
901:): MetricsComparison {
902:  const out: MetricsComparison = {};
903:  const allKeys = new Set([...Object.keys(baseline), ...Object.keys(current)]);
904:  for (const k of allKeys) {
905:    const inB = k in baseline;
906:    const inC = k in current;
907:    if (inB && inC) {
908:      out[k] = compareValue(baseline[k], current[k]) as MetricDelta;
909:    } else if (inB) {
910:      out[k] = { baseline: baseline[k], onlyIn: 'baseline' };
911:    } else {
912:      out[k] = { current: current[k], onlyIn: 'current' };
913:    }
914:  }
915:  return out;
916:}
917:```
