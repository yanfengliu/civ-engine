183:### Step 3: Implement `src/behavioral-metrics.ts` types + `bundleCount` + minimal `runMetrics`
184:
185:- [ ] Create `src/behavioral-metrics.ts`:
186:
187:```ts
188:import type { SessionBundle } from './session-bundle.js';
189:import type { JsonValue } from './json.js';
190:
191:export interface Stats {
192:  count: number;
193:  min: number | null;
194:  max: number | null;
195:  mean: number | null;
196:  p50: number | null;
197:  p95: number | null;
198:  p99: number | null;
199:}
200:
201:export interface Metric<TState, TResult> {
202:  readonly name: string;
203:  create(): TState;
204:  observe(state: TState, bundle: SessionBundle): TState;
205:  finalize(state: TState): TResult;
206:  merge?(a: TState, b: TState): TState;
207:  readonly orderSensitive?: boolean;
208:}
209:
210:export type MetricsResult = Record<string, unknown>;
211:
212:export function runMetrics<
213:  TEventMap extends Record<keyof TEventMap, unknown> = Record<string, never>,
214:  TCommandMap extends Record<keyof TCommandMap, unknown> = Record<string, never>,
215:  TDebug = JsonValue,
216:>(
217:  bundles: Iterable<SessionBundle<TEventMap, TCommandMap, TDebug>>,
218:  metrics: Metric<unknown, unknown>[],
219:): MetricsResult {
220:  // Validate uniqueness.
221:  const names = new Set<string>();
222:  for (const m of metrics) {
223:    if (names.has(m.name)) {
224:      throw new RangeError(`duplicate metric name: ${m.name}`);
225:    }
226:    names.add(m.name);
227:  }
228:  // Initialize accumulator state.
229:  const states: unknown[] = metrics.map((m) => m.create());
230:  // Single-pass observe.
231:  for (const bundle of bundles) {
232:    for (let i = 0; i < metrics.length; i++) {
233:      states[i] = metrics[i].observe(states[i], bundle as unknown as SessionBundle);
234:    }
235:  }
236:  // Finalize.
237:  const result: MetricsResult = {};
238:  for (let i = 0; i < metrics.length; i++) {
239:    result[metrics[i].name] = metrics[i].finalize(states[i]);
240:  }
241:  return result;
242:}
243:
244:export function bundleCount(name: string = 'bundleCount'): Metric<{ count: number }, number> {
245:  return {
246:    name,
247:    create: () => ({ count: 0 }),
248:    observe: (state) => {
249:      state.count++;
250:      return state;
251:    },
252:    finalize: (state) => state.count,
253:  };
254:}
255:```
