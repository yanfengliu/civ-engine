262:### Step 5: Add `Stats`-helper internals + `sessionLengthStats`
263:
264:- [ ] Append to `src/behavioral-metrics.ts`:
265:
266:```ts
267:function computeStats(values: number[]): Stats {
268:  const count = values.length;
269:  if (count === 0) {
270:    return { count: 0, min: null, max: null, mean: null, p50: null, p95: null, p99: null };
271:  }
272:  const sorted = [...values].sort((a, b) => a - b);
273:  const min = sorted[0];
274:  const max = sorted[count - 1];
275:  const mean = sorted.reduce((s, v) => s + v, 0) / count;
276:  // NumPy linear / R type 7 percentile.
277:  const percentile = (p: number): number => {
278:    if (count === 1) return sorted[0];
279:    const idx = (count - 1) * p;
280:    const lo = Math.floor(idx);
281:    const hi = Math.ceil(idx);
282:    return sorted[lo] + (sorted[hi] - sorted[lo]) * (idx - lo);
283:  };
284:  return {
285:    count, min, max, mean,
286:    p50: percentile(0.5), p95: percentile(0.95), p99: percentile(0.99),
287:  };
288:}
289:
290:export function sessionLengthStats(name: string = 'sessionLengthStats'): Metric<number[], Stats> {
291:  return {
292:    name,
293:    create: () => [],
294:    observe: (state, bundle) => {
295:      state.push(bundle.metadata.durationTicks);
296:      return state;
297:    },
298:    finalize: (state) => computeStats(state),
299:  };
300:}
301:```
