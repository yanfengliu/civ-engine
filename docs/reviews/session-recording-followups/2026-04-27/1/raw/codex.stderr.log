= JsonValue> {
docs\design\2026-04-26-session-recording-and-replay-design.md:275:  addMarker(marker: NewMarker): MarkerId;     // 
tick defaults to world.tick if omitted
docs\design\2026-04-26-session-recording-and-replay-design.md:276:  attach(blob: { mime: string; data: Uint8Array }, 
options?: { sidecar?: boolean }): AttachmentId;
