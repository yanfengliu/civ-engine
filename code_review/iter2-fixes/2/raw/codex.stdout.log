45:export class SpatialGrid {
46:  readonly width: number;
47:  readonly height: number;
48:  private cells = new Map<number, Set<EntityId>>();
49:
50:  constructor(width: number, height: number) {
51:    assertPositiveInteger(width, 'width');
52:    assertPositiveInteger(height, 'height');
53:    this.width = width;
54:    this.height = height;
55:  }
56:
57:  insert(entity: EntityId, x: number, y: number): void {
58:    const key = this.key(x, y);
59:    let cell = this.cells.get(key);
60:    if (!cell) {
61:      cell = new Set();
62:      this.cells.set(key, cell);
63:    }
64:    cell.add(entity);
65:  }
66:
67:  remove(entity: EntityId, x: number, y: number): void {
68:    const key = this.key(x, y);
69:    const cell = this.cells.get(key);
70:    if (!cell) return;
71:    cell.delete(entity);
72:    if (cell.size === 0) {
73:      this.cells.delete(key);
74:    }
75:  }
76:
77:  move(
78:    entity: EntityId,
79:    fromX: number,
80:    fromY: number,
81:    toX: number,
82:    toY: number,
83:  ): void {
84:    this.remove(entity, fromX, fromY);
85:    this.insert(entity, toX, toY);
86:  }
87:
88:  getAt(x: number, y: number): ReadonlySet<EntityId> | null {
89:    return this.cells.get(this.key(x, y)) ?? null;
90:  }
91:
92:  getNeighbors(
93:    x: number,
94:    y: number,
95:    offsets: ReadonlyArray<[number, number]> = ORTHOGONAL,
96:  ): EntityId[] {
97:    this.assertBounds(x, y);
98:    const result: EntityId[] = [];
99:    for (const [dx, dy] of offsets) {
100:      const nx = x + dx;
101:      const ny = y + dy;
102:      if (nx >= 0 && nx < this.width && ny >= 0 && ny < this.height) {
103:        const cell = this.cells.get(this.uncheckedKey(nx, ny));
104:        if (cell) {
105:          for (const entity of cell) {
106:            result.push(entity);
107:          }
108:        }
109:      }
110:    }
111:    return result;
112:  }
113:
114:  getInRadius(
115:    cx: number,
116:    cy: number,
117:    radius: number,
118:    metric: 'euclidean' | 'manhattan' = 'euclidean',
119:  ): EntityId[] {
120:    this.assertBounds(cx, cy);
121:    if (!Number.isFinite(radius) || radius < 0) {
122:      throw new RangeError(`Radius ${radius} is invalid`);
123:    }
124:    const r = Math.ceil(radius);
125:    const minX = Math.max(0, cx - r);
126:    const maxX = Math.min(this.width - 1, cx + r);
127:    const minY = Math.max(0, cy - r);
128:    const maxY = Math.min(this.height - 1, cy + r);
129:    const radiusSq = radius * radius;
130:    const result: EntityId[] = [];
131:
132:    for (let y = minY; y <= maxY; y++) {
133:      for (let x = minX; x <= maxX; x++) {
134:        const dx = x - cx;
135:        const dy = y - cy;
136:        const inRange =
137:          metric === 'manhattan'
138:            ? Math.abs(dx) + Math.abs(dy) <= radius
139:            : dx * dx + dy * dy <= radiusSq;
140:        if (!inRange) continue;
141:        const cell = this.cells.get(this.uncheckedKey(x, y));
142:        if (cell) {
143:          for (const entity of cell) {
144:            result.push(entity);
145:          }
146:        }
147:      }
148:    }
149:    return result;
150:  }
151:
152:  assertBounds(x: number, y: number): void {
153:    if (!Number.isInteger(x) || !Number.isInteger(y)) {
154:      throw new RangeError(`Position (${x}, ${y}) must use integer coordinates`);
155:    }
156:    if (x < 0 || x >= this.width || y < 0 || y >= this.height) {
157:      throw new RangeError(`Position (${x}, ${y}) is out of bounds`);
158:    }
159:  }
160:
161:  private key(x: number, y: number): number {
162:    this.assertBounds(x, y);
163:    return this.uncheckedKey(x, y);
164:  }
165:
166:  private uncheckedKey(x: number, y: number): number {
167:    return y * this.width + x;
168:  }
169:}
